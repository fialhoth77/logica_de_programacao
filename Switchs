2- let diadasemana = Number(prompt("Digite um número de 1 a 7 para saber o dia da semana:"))

switch (diadasemana){
    case 1:
        console.log("Domingo")
        break;
        
    case 2:
        console.log("Segunda-Feira")
        break;
        
    case 3:
        console.log("Terça-Feira")
        break;
        
    case 4:
        console.log("Quarta-Feira")
        break;
        
    case 5:
        console.log("Quinta-Feira")
        break;
        
    case 6:
        console.log("Sexta-Feira")
        break;
        
    case 7:
        console.log("Sábado")
        break;
        
    default:
    console.log("Dia da semana não encontrado")
}

